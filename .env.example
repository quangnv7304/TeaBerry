DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=

# Mặc định email được in ra terminal khi phát triển.
# Để gửi email thật, đổi backend sang SMTP và điền thông tin bên dưới.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_DEFAULT_FROM_EMAIL=TeaBerry <noreply@teaberry.local>

DATABASE_URL=

TEABERRY_BANK_CODE=VCB
TEABERRY_BANK_NAME=Vietcombank
TEABERRY_BANK_ACCOUNT=replace-me
TEABERRY_BANK_HOLDER=replace-me
